# Optional — all features work without any API keys

# Local LLM via Ollama (free). Falls back to built-in templates if unavailable.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Microsoft Edge TTS voice (free, no key needed)
# Options: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural, etc.
TTS_VOICE=en-US-ChristopherNeural

# Video output (YouTube Shorts 9:16)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# Server
HOST=0.0.0.0
PORT=8000
